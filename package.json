{
  "name": "@tarmo-randma/pi-superpowers-adapter",
  "version": "0.1.3",
  "description": "Minimal Pi adapter for upstream obra/superpowers skills.",
  "license": "MIT",
  "type": "module",
  "keywords": ["pi-package", "pi-extension", "skills", "superpowers"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarmo-randma/pi-superpowers-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/tarmo-randma/pi-superpowers-adapter/issues"
  },
  "homepage": "https://github.com/tarmo-randma/pi-superpowers-adapter#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "pi": {
    "extensions": ["./src/index.ts"],
    "skills": ["./node_modules/obra-superpowers/skills"]
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.75.5",
    "obra-superpowers": "https://github.com/obra/superpowers/archive/refs/tags/v5.1.0.tar.gz"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@types/node": "^24.0.0",
    "typebox": "^1.0.55",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  }
}
