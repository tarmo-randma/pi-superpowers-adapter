{
  "name": "pi-superpowers-adapter",
  "version": "0.1.0",
  "description": "Minimal Pi adapter for upstream obra/superpowers skills.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "keywords": ["pi-package", "pi-extension", "skills", "superpowers"],
  "pi": {
    "extensions": ["./src/index.ts"],
    "skills": ["./node_modules/obra-superpowers/skills"]
  },
  "dependencies": {
    "obra-superpowers": "https://github.com/obra/superpowers/archive/refs/tags/v5.1.0.tar.gz"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@types/node": "^24.0.0",
    "typebox": "^1.0.55",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
}
